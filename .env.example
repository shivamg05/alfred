# iMessage
ALFRED_PHONE=alfred.yourname@icloud.com   # The Apple ID Alfred listens on (second Apple ID)
USER_PHONE=+1xxxxxxxxxx                   # Your phone number Alfred replies to

# AI (OpenAI-compatible — works with OpenAI, Gemini via OpenAI compat, Groq, etc.)
OPENAI_API_KEY=sk-...
# Optional: point to a cheaper provider (e.g. Gemini Flash via OpenAI-compatible endpoint)
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
LLM_MODEL=gpt-4o-mini
EXTRACTION_MODEL=gpt-4o-mini

# Storage
DB_PATH=alfred.db
CHROMA_PATH=./chroma_data
CHROMA_PORT=8000

# Integrations (optional)
# TODOIST_API_TOKEN=...
# FIRECRAWL_API_KEY=fc-...

# Behaviour
QUIET_HOURS_START=23   # hour (24h) Alfred won't text you after
QUIET_HOURS_END=8      # hour (24h) Alfred won't text you before
USER_TIMEZONE=America/Chicago
